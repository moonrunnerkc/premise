# Environment Variables for Premise MCP Server

# Required: Anthropic API key for internal LLM calls (analysis, simulation, coaching)
ANTHROPIC_API_KEY=sk-ant-...

# Required for Notion MCP server (not used by Premise directly, configured in Claude Desktop)
NOTION_TOKEN=ntn_...

# Optional: Gmail integration for counterparty email context
# GOOGLE_CREDENTIALS_FILE=credentials.json
# GOOGLE_TOKEN_FILE=token.json

# Server config
PREMISE_MODEL=claude-sonnet-4-20250514
PREMISE_LOG_LEVEL=info

# When set, reads responses from this directory instead of calling the Anthropic API
# PREMISE_MOCK_DIR=demo/mock-responses

# When set, captures raw API responses to this directory for later use as mock fixtures
# PREMISE_CAPTURE_DIR=demo/mock-responses
