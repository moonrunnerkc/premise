{
  "name": "premise",
  "version": "0.1.0",
  "description": "Evidence-grounded preparation system for high-stakes conversations, built on Notion MCP",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "premise": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "notion",
    "negotiation",
    "preparation"
  ],
  "author": "moonrunnerkc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moonrunnerkc/premise.git"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@notionhq/client": "^5.12.0",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
